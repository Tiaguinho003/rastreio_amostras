# Canonical example for `internal-production` compose/runtime.
# Copy this file to `.env.internal-production`.

APP_PORT=3001
APP_BASE_URL=http://HOSTNAME-OU-IP-LAN:3001

INTERNAL_PRODUCTION_DB_HOST=127.0.0.1
INTERNAL_PRODUCTION_DB_PORT=55433

POSTGRES_USER=rastreio_app
POSTGRES_PASSWORD=change-me-internal-production-db-password
POSTGRES_DB=rastreio_internal_production
POSTGRES_DATA_DIR=/srv/rastreio/internal-production/postgres

UPLOADS_HOST_DIR=/srv/rastreio/internal-production/uploads
EMAIL_OUTBOX_HOST_DIR=/srv/rastreio/internal-production/email-outbox
BACKUP_ROOT=/srv/rastreio/internal-production/backups

AUTH_SECRET=replace-with-strong-secret-min-32-chars
SESSION_COOKIE_SECURE=false

BOOTSTRAP_ADMIN_FULL_NAME="Administrador Internal Production"
BOOTSTRAP_ADMIN_USERNAME=admin_internal
BOOTSTRAP_ADMIN_EMAIL=admin-internal@example.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.empresa.local
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario-smtp
SMTP_PASS=senha-smtp
SMTP_FROM=no-reply@empresa.local

# `false`: piloto LAN em HTTP interno
# `auto`: usa HTTPS quando o request realmente chega como HTTPS
# `true`: forca cookie Secure em qualquer request
# SESSION_COOKIE_SECURE=auto

# Pilot fallback when SMTP is not ready yet:
# EMAIL_TRANSPORT=outbox
# EMAIL_OUTBOX_FROM=rastreio@safras.local
