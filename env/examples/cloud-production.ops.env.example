# Canonical example for Google Cloud production ops environment.
# Copy to .env.cloud-production.ops and customize with your project's values.
# GCLOUD_IMAGE_TAG is derived automatically from git rev-parse --short HEAD.

GCLOUD_PROJECT_ID=your-project-id
GCLOUD_REGION=southamerica-east1
GCLOUD_ARTIFACT_REGISTRY_REPOSITORY=rastreio-production
GCLOUD_IMAGE_NAME=rastreio-interno-amostras

GCLOUD_CLOUD_RUN_SERVICE=rastreio-prod-app
GCLOUD_CLOUD_RUN_MIGRATE_JOB=rastreio-prod-migrate
GCLOUD_CLOUD_RUN_SEED_JOB=rastreio-prod-seed
GCLOUD_SERVICE_ACCOUNT=rastreio-prod-runtime@your-project-id.iam.gserviceaccount.com

GCLOUD_CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project-id:southamerica-east1:rastreio-prod-pg
GCLOUD_STORAGE_BUCKET=your-prod-runtime-bucket
GCLOUD_STORAGE_MOUNT_PATH=/mnt/runtime

GCLOUD_SECRET_DATABASE_URL=rastreio-prod-database-url
GCLOUD_SECRET_AUTH_SECRET=rastreio-prod-auth-secret
GCLOUD_SECRET_BOOTSTRAP_ADMIN_FULL_NAME=rastreio-prod-bootstrap-admin-full-name
GCLOUD_SECRET_BOOTSTRAP_ADMIN_USERNAME=rastreio-prod-bootstrap-admin-username
GCLOUD_SECRET_BOOTSTRAP_ADMIN_EMAIL=rastreio-prod-bootstrap-admin-email
GCLOUD_SECRET_BOOTSTRAP_ADMIN_PASSWORD=rastreio-prod-bootstrap-admin-password
GCLOUD_SECRET_SMTP_PASS=rastreio-prod-smtp-pass
GCLOUD_SECRET_OPENAI_API_KEY=rastreio-prod-openai-api-key

GCLOUD_CPU=1
GCLOUD_MEMORY=1Gi
GCLOUD_CONCURRENCY=10
GCLOUD_MIN_INSTANCES=0
GCLOUD_MAX_INSTANCES=3
GCLOUD_TIMEOUT_SECONDS=300
GCLOUD_ALLOW_UNAUTHENTICATED=true

SMOKE_USERNAME=admin
SMOKE_PASSWORD=example
