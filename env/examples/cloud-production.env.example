# Canonical example for Google Cloud production runtime.
# Copy to .env.cloud-production and customize.
# Sensitive values (DATABASE_URL, AUTH_SECRET, BOOTSTRAP_ADMIN_*, SMTP_PASS) come from Secret Manager.

APP_BASE_URL=https://placeholder.invalid

SESSION_COOKIE_SECURE=auto

EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=no-reply@example.com
SMTP_USER=no-reply@example.com

UPLOADS_DIR=/mnt/runtime/uploads
MAX_UPLOAD_SIZE_BYTES=8388608
