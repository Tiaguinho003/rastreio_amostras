# Canonical example for Google Cloud homologation runtime.
# Copy this file to `.env.cloud-homolog`.

# Runtime public URL.
# The deploy script can update APP_BASE_URL to the generated run.app URL after the first deploy.
APP_BASE_URL=https://SERVICE---HASH-uc.a.run.app

# Runtime contract for Cloud Run + Cloud SQL via Unix socket.
# In homologation these sensitive values should come from Secret Manager, not from the env file.
# DATABASE_URL=postgresql://USER:PASSWORD@localhost/DB?host=/cloudsql/PROJECT:REGION:INSTANCE&schema=public
# AUTH_SECRET=replace-with-strong-secret-min-32-chars

SESSION_COOKIE_SECURE=auto
EMAIL_TRANSPORT=outbox
EMAIL_OUTBOX_DIR=/mnt/runtime/email-outbox
EMAIL_OUTBOX_FROM=rastreio-homolog@example.local
UPLOADS_DIR=/mnt/runtime/uploads
MAX_UPLOAD_SIZE_BYTES=8388608

# Bootstrap administrator credentials should also come from Secret Manager in homologation:
# BOOTSTRAP_ADMIN_FULL_NAME="Administrador Cloud Homolog"
# BOOTSTRAP_ADMIN_USERNAME=admin_cloud_homolog
# BOOTSTRAP_ADMIN_EMAIL=admin-cloud-homolog@example.local
# BOOTSTRAP_ADMIN_PASSWORD=change-me-now
