# Canonical example for local `development`.
# Copy this file to `.env.development`.

DEVELOPMENT_DB_PORT=55432

POSTGRES_USER=rastreio_app
POSTGRES_PASSWORD=rastreio_app
POSTGRES_DB=rastreio_test

DATABASE_URL=postgresql://rastreio_app:rastreio_app@localhost:55432/rastreio_test?schema=public

AUTH_SECRET=replace-with-strong-secret-min-16-chars

BOOTSTRAP_ADMIN_FULL_NAME="Administrador Development"
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

EMAIL_TRANSPORT=outbox
EMAIL_OUTBOX_DIR=./.runtime/development/email-outbox
EMAIL_OUTBOX_FROM=rastreio@safras.local

UPLOADS_DIR=./.runtime/development/uploads
BACKUP_ROOT=./.runtime/development/backups

APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://127.0.0.1:3000
SESSION_COOKIE_SECURE=false

SMOKE_USERNAME=admin
SMOKE_PASSWORD=change-me-now

# Optional one-time import from legacy env auth during seed
# LOCAL_AUTH_USERS_JSON='[{"id":"00000000-0000-0000-0000-000000000001","username":"admin","password":"change-me-now","role":"ADMIN","displayName":"Administrador"}]'
