# Legacy compatibility template kept in root during Phase 1.
# Canonical internal-production example: env/examples/internal-production.env.example

# Production environment template

APP_PORT=3000
APP_BASE_URL=https://app.empresa.com.br

POSTGRES_USER=rastreio_app
POSTGRES_PASSWORD=change-me-prod-db-password
POSTGRES_DB=rastreio_prod
POSTGRES_DATA_DIR=/srv/rastreio/producao/postgres
UPLOADS_HOST_DIR=/srv/rastreio/producao/uploads
EMAIL_OUTBOX_HOST_DIR=/srv/rastreio/producao/email-outbox

AUTH_SECRET=replace-with-strong-secret-min-32-chars
SESSION_COOKIE_SECURE=false

BOOTSTRAP_ADMIN_FULL_NAME="Administrador Producao"
BOOTSTRAP_ADMIN_USERNAME=admin_prod
BOOTSTRAP_ADMIN_EMAIL=admin@empresa.com.br
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.empresa.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario-smtp
SMTP_PASS=senha-smtp
SMTP_FROM=no-reply@empresa.com.br

BACKUP_ROOT=/srv/rastreio/producao/backups
API_BASE_URL=http://localhost:3000
SMOKE_USERNAME=admin_prod
SMOKE_PASSWORD=replace-with-known-production-password
