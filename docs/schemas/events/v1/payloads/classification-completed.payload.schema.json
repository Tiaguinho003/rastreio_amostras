{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/classification-completed.payload.schema.json",
  "title": "CLASSIFICATION_COMPLETED payload",
  "type": "object",
  "properties": {
    "classificationPhotoId": {
      "type": "string",
      "minLength": 1
    },
    "classificationVersion": {
      "type": "integer",
      "minimum": 1
    },
    "classificationType": {
      "type": ["string", "null"],
      "enum": ["BICA", "PREPARADO", "BAIXO", "ESCOLHA", "CONILON", null]
    },
    "classificationData": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataClassificacao": {
          "type": ["string", "null"],
          "format": "date"
        },
        "padrao": { "type": ["string", "null"] },
        "aspecto": { "type": ["string", "null"] },
        "certif": { "type": ["string", "null"] },
        "catacao": { "type": ["string", "null"] },
        "observacoes": { "type": ["string", "null"] },
        "bebida": { "type": ["string", "null"] },
        "peneiras": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "p18": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p17": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p16": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p15": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p14": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p13": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p12": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p11": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "p10": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "mk": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          }
        },
        "fundos": {
          "type": ["array", "null"],
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "peneira": { "type": ["string", "null"] },
              "percentual": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
            },
            "required": ["peneira", "percentual"]
          }
        },
        "defeitos": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "imp": { "type": ["string", "null"] },
            "pva": { "type": ["string", "null"] },
            "broca": { "type": ["string", "null"] },
            "gpi": { "type": ["string", "null"] },
            "ap": { "type": ["string", "null"] },
            "defeito": { "type": ["string", "null"] }
          }
        }
      }
    },
    "technical": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "screen": { "type": "string", "minLength": 1 },
        "defectsCount": { "type": "integer", "minimum": 0 },
        "density": { "type": ["number", "null"], "minimum": 0 },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "classifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "fullName": { "type": "string", "minLength": 1 },
          "username": { "type": "string", "minLength": 1 }
        },
        "required": ["id", "fullName", "username"],
        "additionalProperties": false
      },
      "minItems": 1,
      "maxItems": 50
    },
    "consumptionGrams": {
      "type": ["number", "null"],
      "minimum": 0
    }
  },
  "required": ["classificationPhotoId"],
  "additionalProperties": false
}
