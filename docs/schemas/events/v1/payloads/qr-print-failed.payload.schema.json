{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/qr-print-failed.payload.schema.json",
  "title": "QR_PRINT_FAILED payload",
  "type": "object",
  "properties": {
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "printerId": {
      "type": ["string", "null"]
    },
    "error": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["attemptNumber", "printerId", "error"],
  "additionalProperties": false
}
