{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/payloads/loss-updated.payload.schema.json",
  "title": "LOSS_UPDATED payload",
  "type": "object",
  "properties": {
    "movementId": { "$ref": "../base/shared-defs.schema.json#/$defs/uuid" },
    "before": { "type": "object", "minProperties": 1 },
    "after": { "type": "object", "minProperties": 1 },
    "reasonText": { "type": "string", "minLength": 1 },
    "soldSacks": { "type": "integer", "minimum": 0 },
    "lostSacks": { "type": "integer", "minimum": 0 },
    "availableSacks": { "type": "integer", "minimum": 0 },
    "commercialStatus": { "$ref": "../base/shared-defs.schema.json#/$defs/commercialStatus" }
  },
  "required": ["movementId", "before", "after", "reasonText", "soldSacks", "lostSacks", "availableSacks", "commercialStatus"],
  "additionalProperties": false
}
