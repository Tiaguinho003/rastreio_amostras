{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/payloads/qr-reprint-requested.payload.schema.json",
  "title": "QR_REPRINT_REQUESTED payload",
  "type": "object",
  "properties": {
    "printAction": {
      "const": "REPRINT"
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "printerId": {
      "type": ["string", "null"]
    },
    "reasonText": {
      "type": ["string", "null"]
    }
  },
  "required": ["printAction", "attemptNumber", "printerId", "reasonText"],
  "additionalProperties": false
}
