{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/qr-printed.payload.schema.json",
  "title": "QR_PRINTED payload",
  "type": "object",
  "properties": {
    "printAction": {
      "$ref": "../base/shared-defs.schema.json#/$defs/printAction"
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "printerId": {
      "type": ["string", "null"]
    },
    "legacy": {
      "type": "object",
      "description": "Presente quando a impressao foi pulada (ex: backfill historico). Indica que o evento e sintetico e nao corresponde a uma impressao real.",
      "properties": {
        "skipped": { "const": true }
      },
      "required": ["skipped"],
      "additionalProperties": false
    }
  },
  "required": ["printAction", "attemptNumber", "printerId"],
  "additionalProperties": false
}
