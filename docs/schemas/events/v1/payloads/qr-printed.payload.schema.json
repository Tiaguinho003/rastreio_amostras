{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/payloads/qr-printed.payload.schema.json",
  "title": "QR_PRINTED payload",
  "type": "object",
  "properties": {
    "printAction": {
      "$ref": "../base/shared-defs.schema.json#/$defs/printAction"
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "printerId": {
      "type": ["string", "null"]
    }
  },
  "required": ["printAction", "attemptNumber", "printerId"],
  "additionalProperties": false
}
