{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/payloads/ocr-extracted.payload.schema.json",
  "title": "OCR_EXTRACTED payload",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["LOCAL", "EXTERNAL"]
    },
    "overallConfidence": {
      "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore"
    },
    "fieldConfidence": {
      "type": "object",
      "properties": {
        "owner": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" },
        "sacks": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" },
        "harvest": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" },
        "originLot": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" }
      },
      "additionalProperties": false
    },
    "extracted": {
      "type": "object",
      "properties": {
        "owner": { "type": ["string", "null"] },
        "sacks": { "type": ["integer", "null"], "minimum": 0 },
        "harvest": { "type": ["string", "null"] },
        "originLot": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "rawTextRef": {
      "type": ["string", "null"]
    }
  },
  "required": ["provider", "overallConfidence"],
  "additionalProperties": false
}
