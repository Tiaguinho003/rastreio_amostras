{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/payloads/physical-sample-sent.payload.schema.json",
  "title": "PHYSICAL_SAMPLE_SENT payload",
  "type": "object",
  "properties": {
    "recipientClientId": {
      "oneOf": [
        { "$ref": "../base/shared-defs.schema.json#/$defs/uuid" },
        { "type": "null" }
      ]
    },
    "recipientClientSnapshot": { "type": ["object", "null"] },
    "sentDate": {
      "type": "string",
      "format": "date"
    }
  },
  "required": ["sentDate"],
  "additionalProperties": false
}
