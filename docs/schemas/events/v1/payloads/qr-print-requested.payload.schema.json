{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/qr-print-requested.payload.schema.json",
  "title": "QR_PRINT_REQUESTED payload",
  "type": "object",
  "properties": {
    "printAction": {
      "const": "PRINT"
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "printerId": {
      "type": ["string", "null"]
    },
    "legacy": {
      "type": "object",
      "description": "Presente quando a impressao foi pulada (ex: backfill historico). Quando skipped=true, nenhum PrintJob e criado e o Print Agent nao recebe o pedido.",
      "properties": {
        "skipped": { "const": true }
      },
      "required": ["skipped"],
      "additionalProperties": false
    }
  },
  "required": ["printAction", "attemptNumber", "printerId"],
  "additionalProperties": false
}
