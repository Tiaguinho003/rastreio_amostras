{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/payloads/registration-confirmed.payload.schema.json",
  "title": "REGISTRATION_CONFIRMED payload",
  "type": "object",
  "properties": {
    "sampleLotNumber": {
      "type": "string",
      "pattern": "^AM-[0-9]{4}-[0-9]{6}$"
    },
    "declared": {
      "type": "object",
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "sacks": { "type": "integer", "minimum": 1 },
        "harvest": { "type": "string", "minLength": 1 },
        "originLot": { "type": "string", "minLength": 1 }
      },
      "required": ["owner", "sacks", "harvest", "originLot"],
      "additionalProperties": false
    },
    "labelPhotos": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 0
    },
    "ocr": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["LOCAL", "EXTERNAL"]
        },
        "overallConfidence": {
          "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore"
        },
        "fieldConfidence": {
          "type": "object",
          "properties": {
            "owner": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" },
            "sacks": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" },
            "harvest": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" },
            "originLot": { "$ref": "../base/shared-defs.schema.json#/$defs/confidenceScore" }
          },
          "required": ["owner", "sacks", "harvest", "originLot"],
          "additionalProperties": false
        },
        "rawTextRef": {
          "type": ["string", "null"]
        }
      },
      "required": ["provider", "overallConfidence", "fieldConfidence", "rawTextRef"],
      "additionalProperties": false
    }
  },
  "required": ["sampleLotNumber", "declared", "ocr"],
  "additionalProperties": false
}
