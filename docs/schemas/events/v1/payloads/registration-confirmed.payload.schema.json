{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/registration-confirmed.payload.schema.json",
  "title": "REGISTRATION_CONFIRMED payload",
  "type": "object",
  "properties": {
    "sampleLotNumber": {
      "type": "string",
      "pattern": "^A-[0-9]+$"
    },
    "declared": {
      "type": "object",
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "sacks": { "type": "integer", "minimum": 1 },
        "harvest": { "type": "string", "minLength": 1 },
        "originLot": { "type": ["string", "null"] },
        "location": { "type": ["string", "null"] }
      },
      "required": ["owner", "sacks", "harvest"],
      "additionalProperties": false
    },
    "ownerClientId": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "ownerBranchId": {
      "type": ["string", "null"],
      "minLength": 1
    }
  },
  "required": ["sampleLotNumber", "declared"],
  "additionalProperties": false
}
