{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/registration-confirmed.payload.schema.json",
  "title": "REGISTRATION_CONFIRMED payload",
  "type": "object",
  "properties": {
    "sampleLotNumber": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "declared": {
      "type": "object",
      "properties": {
        "owner": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Nome do dono em texto livre. Pode ser null em registros de liga (isBlend=true) quando ownerClientId tambem e null — Liga F3.1 + F3.3 (carteira da corretora). Quando string, minLength=1."
        },
        "sacks": { "type": "integer", "minimum": 1 },
        "harvest": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Safra do cafe (ex: '24/25'). Pode ser null em registros de liga (isBlend=true) — Liga F3.2 revogada em 2026-05-19: backend deriva automaticamente das origens (distinct ordenado, join ', '). Sample normal sempre tem string non-empty (form valida)."
        },
        "originLot": { "type": ["string", "null"] },
        "location": { "type": ["string", "null"] }
      },
      "required": ["owner", "sacks", "harvest"],
      "additionalProperties": false
    },
    "ownerClientId": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "ownerUnitId": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "receivedChannel": {
      "type": "string",
      "enum": ["in_person", "courier", "driver", "other", "internal"]
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "required": ["sampleLotNumber", "declared", "receivedChannel"],
  "additionalProperties": false
}
