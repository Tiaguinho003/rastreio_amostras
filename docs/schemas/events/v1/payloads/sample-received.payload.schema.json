{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/payloads/sample-received.payload.schema.json",
  "title": "SAMPLE_RECEIVED payload",
  "type": "object",
  "properties": {
    "receivedChannel": {
      "type": "string",
      "enum": ["in_person", "courier", "driver", "other", "legacy_backfill"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "legacy": {
      "type": "object",
      "description": "Presente apenas em amostras criadas via backfill historico. Quando presente, projeta source/internalLotNumber/createdAt diretamente na Sample na criacao.",
      "properties": {
        "internalLotNumber": {
          "type": "string",
          "pattern": "^A-[0-9]+$"
        },
        "source": {
          "type": "string",
          "const": "LEGACY_BACKFILL"
        }
      },
      "required": ["internalLotNumber", "source"],
      "additionalProperties": false
    }
  },
  "required": ["receivedChannel"],
  "additionalProperties": false
}
