{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/events/classification-started.event.schema.json",
  "title": "CLASSIFICATION_STARTED event",
  "allOf": [
    { "$ref": "../base/event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "CLASSIFICATION_STARTED" },
        "schemaVersion": { "const": 1 },
        "payload": { "$ref": "../payloads/classification-started.payload.schema.json" },
        "fromStatus": { "enum": ["REGISTRATION_CONFIRMED", "QR_PENDING_PRINT", "QR_PRINTED"] },
        "toStatus": { "const": "CLASSIFICATION_IN_PROGRESS" }
      },
      "required": ["eventType", "schemaVersion", "payload", "fromStatus", "toStatus"]
    }
  ]
}
