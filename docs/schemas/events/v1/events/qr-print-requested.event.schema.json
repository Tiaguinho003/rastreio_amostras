{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/events/qr-print-requested.event.schema.json",
  "title": "QR_PRINT_REQUESTED event",
  "allOf": [
    { "$ref": "../base/event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "QR_PRINT_REQUESTED" },
        "schemaVersion": { "const": 1 },
        "payload": { "$ref": "../payloads/qr-print-requested.payload.schema.json" },
        "fromStatus": { "const": "REGISTRATION_CONFIRMED" },
        "toStatus": { "const": "QR_PENDING_PRINT" },
        "idempotencyScope": { "const": "QR_PRINT" },
        "idempotencyKey": { "type": "string", "minLength": 1 }
      },
      "required": [
        "eventType",
        "schemaVersion",
        "payload",
        "fromStatus",
        "toStatus",
        "idempotencyScope",
        "idempotencyKey"
      ]
    }
  ]
}
