{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/events/qr-printed.event.schema.json",
  "title": "QR_PRINTED event",
  "description": "Q.print: impressao virou acao pura. Audit-only (fromStatus=null/toStatus=null) — nao muda mais o status do sample. PrintJob.status='SUCCESS' atualizado em paralelo.",
  "allOf": [
    { "$ref": "../base/event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "QR_PRINTED" },
        "schemaVersion": { "const": 1 },
        "payload": { "$ref": "../payloads/qr-printed.payload.schema.json" },
        "fromStatus": { "type": "null" },
        "toStatus": { "type": "null" }
      },
      "required": ["eventType", "schemaVersion", "payload", "fromStatus", "toStatus"]
    }
  ]
}
