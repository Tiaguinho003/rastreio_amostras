{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rastreio-interno-amostras.local/schemas/events/v1/events/classification-completed.event.schema.json",
  "title": "CLASSIFICATION_COMPLETED event",
  "allOf": [
    { "$ref": "../base/event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "CLASSIFICATION_COMPLETED" },
        "schemaVersion": { "const": 1 },
        "payload": { "$ref": "../payloads/classification-completed.payload.schema.json" },
        "fromStatus": { "enum": ["REGISTRATION_CONFIRMED", "QR_PENDING_PRINT", "QR_PRINTED", "CLASSIFICATION_IN_PROGRESS"] },
        "toStatus": { "const": "CLASSIFIED" },
        "idempotencyScope": { "const": "CLASSIFICATION_COMPLETE" },
        "idempotencyKey": { "type": "string", "minLength": 1 }
      },
      "required": [
        "eventType",
        "schemaVersion",
        "payload",
        "fromStatus",
        "toStatus",
        "idempotencyScope",
        "idempotencyKey"
      ]
    }
  ]
}
