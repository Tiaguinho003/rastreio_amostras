{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amostras-safras.local/schemas/events/v1/events/registration-confirmed.event.schema.json",
  "title": "REGISTRATION_CONFIRMED event",
  "allOf": [
    { "$ref": "../base/event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "REGISTRATION_CONFIRMED" },
        "schemaVersion": { "const": 1 },
        "payload": { "$ref": "../payloads/registration-confirmed.payload.schema.json" },
        "fromStatus": { "const": "REGISTRATION_IN_PROGRESS" },
        "toStatus": { "const": "REGISTRATION_CONFIRMED" },
        "idempotencyScope": { "const": "REGISTRATION_CONFIRM" },
        "idempotencyKey": { "type": "string", "minLength": 1 }
      },
      "required": [
        "eventType",
        "schemaVersion",
        "payload",
        "fromStatus",
        "toStatus",
        "idempotencyScope",
        "idempotencyKey"
      ]
    }
  ]
}
