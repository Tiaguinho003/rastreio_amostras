# === Safras Print Agent - Configuracao ===

# Backend (URL do sistema em producao)
BACKEND_URL=https://rastreio-prod-app-r4au5o2iea-rj.a.run.app

# Credenciais do usuario print-agent (criar no sistema com role Registro)
AGENT_USERNAME=print-agent
AGENT_PASSWORD=CHANGE_ME

# Impressora Elgin L42 Pro (nome exato no Windows)
# Para descobrir o nome, abra o PowerShell e execute:
#   Get-Printer | Select-Object Name
# Use o nome exato da impressora (ex: Elgin L42 Pro)
PRINTER_NAME=Elgin L42 Pro
PRINTER_ID=elgin-l42-office

# Intervalo de polling em milissegundos (padrao: 7000 = 7 segundos)
POLL_INTERVAL_MS=7000

# Retry de impressao: tentativas antes de reportar falha (padrao: 3)
PRINT_RETRY_COUNT=3

# Delay base entre retries em milissegundos (padrao: 2000 = 2s)
# Usa backoff exponencial: 2s, 4s, 8s
PRINT_RETRY_DELAY_MS=2000

# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
