generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SampleStatus {
  REGISTRATION_CONFIRMED
  CLASSIFIED
  INVALIDATED
}

enum ActorType {
  USER
  SYSTEM
}

enum SourceType {
  WEB    @map("web")
  API    @map("api")
  WORKER @map("worker")
}

enum ModuleType {
  REGISTRATION   @map("registration")
  CLASSIFICATION @map("classification")
  PRINT          @map("print")
  COMMERCIAL     @map("commercial")
}

enum IdempotencyScope {
  REGISTRATION_CONFIRM
  QR_PRINT
  CLASSIFICATION_COMPLETE
  COMMERCIAL_STATUS_UPDATE
  INVALIDATE
  BLEND_CREATE
  BLEND_REVERT
}

enum SampleEventType {
  PHOTO_ADDED
  REGISTRATION_CONFIRMED
  QR_PRINT_REQUESTED
  QR_PRINT_FAILED
  QR_PRINTED
  CLASSIFICATION_COMPLETED
  REGISTRATION_UPDATED
  CLASSIFICATION_UPDATED
  SALE_CREATED
  SALE_UPDATED
  SALE_CANCELLED
  LOSS_RECORDED
  LOSS_UPDATED
  LOSS_CANCELLED
  COMMERCIAL_STATUS_UPDATED
  SAMPLE_INVALIDATED
  REPORT_EXPORTED
  PHYSICAL_SAMPLE_SENT
  PHYSICAL_SAMPLE_SEND_UPDATED
  PHYSICAL_SAMPLE_SEND_CANCELLED
  CLASSIFICATION_EXTRACTION_COMPLETED
  CLASSIFICATION_EXTRACTION_FAILED
  BLEND_CREATED
  BLEND_REVERTED
}

enum CommercialStatus {
  OPEN
  PARTIALLY_SOLD
  SOLD
  LOST
}

enum ClientPersonType {
  PF
  PJ
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum ClientUnitStatus {
  ACTIVE
  INACTIVE
}

enum SampleMovementType {
  SALE
  LOSS
}

enum SampleMovementStatus {
  ACTIVE
  CANCELLED
}

enum ClientAuditEventType {
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_INACTIVATED
  CLIENT_REACTIVATED
  // L5/Q-16: cutover removeu CLIENT_REGISTRATION_*, CLIENT_BRANCH_*,
  // CLIENT_SPLIT e CLIENT_BRANCH_CONSOLIDATED. Eventos de unidade sao
  // emitidos em CLIENT_UNIT_*.
  CLIENT_UNIT_CREATED
  CLIENT_UNIT_UPDATED
  CLIENT_UNIT_INACTIVATED
  CLIENT_UNIT_REACTIVATED
}

enum ClassificationType {
  BICA
  PREPARADO
  BAIXO
  ESCOLHA
  CONILON
}

enum AttachmentKind {
  CLASSIFICATION_PHOTO
}

enum PrintJobStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum UserRole {
  ADMIN
  CLASSIFIER
  REGISTRATION
  COMMERCIAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum InitialPasswordDecision {
  PENDING
  KEPT
  CHANGED
}

enum UserSessionEndReason {
  LOGOUT
  EXPIRED
  PASSWORD_CHANGED
  PASSWORD_RESET
  USERNAME_CHANGED
  ROLE_CHANGED
  INACTIVATED
  REVOKED
}

enum UserAuditEventType {
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  USER_INACTIVATED
  USER_REACTIVATED
  USER_UNLOCKED
  PASSWORD_CHANGED
  PASSWORD_RESET_BY_ADMIN
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  LOGOUT
  SESSION_EXPIRED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGE_CONFIRMED
  INITIAL_PASSWORD_DECISION_RECORDED
}

model Sample {
  id                String           @id @db.Uuid
  internalLotNumber String?          @unique(map: "uq_sample_internal_lot") @map("internal_lot_number")
  status            SampleStatus
  commercialStatus  CommercialStatus @default(OPEN) @map("commercial_status")
  version           Int              @default(0)
  lastEventSequence Int              @default(0) @map("last_event_sequence")
  /// Dono da amostra (cliente vinculado). Tambem serve como vendedor implicito
  /// em SampleMovement — relatorios financeiros derivam vendedor desta coluna
  /// via JOIN (Liga F3.A). Em liga sem dono (isBlend=true + ownerClientId=null),
  /// venda aparece como "sem vendedor identificado" (carteira da corretora).
  ownerClientId String? @map("owner_client_id") @db.Uuid
  ownerUnitId   String? @map("owner_unit_id") @db.Uuid
  /// Nome do dono em texto livre (snapshot). Em registros com isBlend=true
  /// sem ownerClientId, e intencionalmente null (Liga T0.C / F3.3).
  declaredOwner   String? @map("declared_owner")
  declaredSacks   Int?    @map("declared_sacks")
  declaredHarvest String? @map("declared_harvest")
  /// Lote de origem em texto livre (Sample normal). Em registros com
  /// isBlend=true, e intencionalmente null — origem real fica em
  /// SampleBlendComponent (Liga T0.C / F3.5).
  declaredOriginLot           String?             @map("declared_origin_lot")
  declaredLocation            String?             @map("declared_location") @db.VarChar(30)
  classificationType          ClassificationType? @map("classification_type")
  soldSacks                   Int                 @default(0) @map("sold_sacks")
  lostSacks                   Int                 @default(0) @map("lost_sacks")
  latestClassificationVersion Int?                @map("latest_classification_version")
  latestClassificationData    Json?               @map("latest_classification_data")
  latestType                  String?             @map("latest_type")
  latestScreen                String?             @map("latest_screen")
  latestDefectsCount          Int?                @map("latest_defects_count")
  latestDensity               Decimal?            @map("latest_density") @db.Decimal(6, 2)
  latestColorAspect           String?             @map("latest_color_aspect")
  latestNotes                 String?             @map("latest_notes")
  classifiedAt                DateTime?           @map("classified_at") @db.Timestamptz(6)
  /// Flag denotando que esta Sample e uma liga (composta de outras
  /// amostras via SampleBlendComponent). Default false — Samples normais
  /// herdam o comportamento atual sem mudanca. Ver docs/Liga-Plano-de-Trabalho.md.
  isBlend   Boolean  @default(false) @map("is_blend")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ownerClient               Client?                @relation("SampleOwnerClient", fields: [ownerClientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ownerUnit                 ClientUnit?            @relation("SampleOwnerUnit", fields: [ownerUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  events                    SampleEvent[]
  attachments               SampleAttachment[]
  printJobs                 PrintJob[]
  movements                 SampleMovement[]
  blendComponents           SampleBlendComponent[] @relation("SampleBlendComponentBlend")
  asOriginInBlendComponents SampleBlendComponent[] @relation("SampleBlendComponentOrigin")

  @@index([status], map: "idx_sample_status")
  @@index([commercialStatus], map: "idx_sample_commercial_status")
  @@index([commercialStatus, updatedAt, id], map: "idx_sample_commercial_updated_id")
  @@index([updatedAt, id], map: "idx_sample_updated_id")
  @@index([declaredOwner], map: "idx_sample_declared_owner")
  @@index([declaredHarvest], map: "idx_sample_declared_harvest")
  @@index([createdAt], map: "idx_sample_created_at")
  @@index([ownerClientId], map: "idx_sample_owner_client")
  @@index([status, updatedAt, id], map: "idx_sample_status_updated_id")
  @@index([status, createdAt, id], map: "idx_sample_status_created_id")
  @@index([status, commercialStatus, classifiedAt], map: "idx_sample_classified_availability")
  @@index([isBlend], map: "idx_sample_is_blend")
  @@map("sample")
}

/// Composicao de uma liga (Sample com isBlend=true). Cada registro vincula
/// a liga (sampleId) a uma amostra de origem (originSampleId) com a quantidade
/// de sacas contribuidas (contributedSacks). Ver Liga F2.3 + T0.D (cascata
/// recursiva). Sem flag de "ativo": registros sao append-only conceitualmente
/// — apos criacao, so podem ser apagados via reversao da liga (BLEND_REVERTED
/// preserva o registro como historico — F8.3).
model SampleBlendComponent {
  id               String   @id @db.Uuid
  /// FK pra Sample que e a liga (isBlend=true).
  sampleId String @map("sample_id") @db.Uuid
  /// FK pra Sample que e origem da contribuicao. Pode ser Sample normal ou
  /// outra liga (Liga Q0.5 — cascata recursiva permitida).
  originSampleId   String   @map("origin_sample_id") @db.Uuid
  /// Sacas contribuidas da origem para a liga. Inteiro (Liga Q0.4).
  /// Quando origem e liga (origin.isBlend=true), e forcado a igualar
  /// origin.declaredSacks (Liga F7.7 — liga em liga = 100% obrigatorio).
  contributedSacks Int      @map("contributed_sacks")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sample       Sample @relation("SampleBlendComponentBlend", fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  originSample Sample @relation("SampleBlendComponentOrigin", fields: [originSampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, originSampleId], map: "uq_blend_component_blend_origin")
  @@index([sampleId], map: "idx_blend_component_sample")
  @@index([originSampleId], map: "idx_blend_component_origin")
  @@map("sample_blend_component")
}

model SampleEvent {
  eventId           String            @id @map("event_id") @db.Uuid
  sampleId          String            @map("sample_id") @db.Uuid
  sequenceNumber    Int               @map("sequence_number")
  eventType         SampleEventType   @map("event_type")
  schemaVersion     Int               @map("schema_version")
  occurredAt        DateTime          @map("occurred_at") @db.Timestamptz(6)
  actorType         ActorType         @map("actor_type")
  actorUserId       String?           @map("actor_user_id") @db.Uuid
  source            SourceType
  payload           Json
  requestId         String            @map("request_id")
  correlationId     String?           @map("correlation_id")
  causationId       String?           @map("causation_id") @db.Uuid
  idempotencyScope  IdempotencyScope? @map("idempotency_scope")
  idempotencyKey    String?           @map("idempotency_key")
  fromStatus        SampleStatus?     @map("from_status")
  toStatus          SampleStatus?     @map("to_status")
  metadataModule    ModuleType        @map("metadata_module")
  metadataIp        String?           @map("metadata_ip")
  metadataUserAgent String?           @map("metadata_user_agent")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  sample          Sample     @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  requestedByJobs PrintJob[] @relation("PrintJobRequestedEvent")
  resultByJobs    PrintJob[] @relation("PrintJobResultEvent")

  @@unique([sampleId, sequenceNumber], map: "uq_sample_event_sequence")
  @@index([sampleId, occurredAt], map: "idx_sample_event_sample_occurred")
  @@index([eventType, occurredAt], map: "idx_sample_event_type_occurred")
  @@index([sampleId, idempotencyScope, idempotencyKey], map: "idx_sample_event_idempotency_lookup")
  @@map("sample_event")
}

model SampleAttachment {
  id             String         @id @db.Uuid
  sampleId       String         @map("sample_id") @db.Uuid
  kind           AttachmentKind
  storagePath    String         @map("storage_path")
  mimeType       String?        @map("mime_type")
  sizeBytes      Int?           @map("size_bytes")
  checksumSha256 String?        @map("checksum_sha256")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  sample Sample @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, kind], map: "uq_sample_attachment_sample_kind")
  @@index([sampleId, createdAt], map: "idx_attachment_sample_created")
  @@map("sample_attachment")
}

model PrintJob {
  id               String         @id @db.Uuid
  sampleId         String         @map("sample_id") @db.Uuid
  attemptNumber    Int            @map("attempt_number")
  status           PrintJobStatus
  printerId        String?        @map("printer_id")
  error            String?
  requestedEventId String         @map("requested_event_id") @db.Uuid
  resultEventId    String?        @map("result_event_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  sample         Sample       @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  requestedEvent SampleEvent  @relation("PrintJobRequestedEvent", fields: [requestedEventId], references: [eventId], onDelete: Restrict, onUpdate: Cascade)
  resultEvent    SampleEvent? @relation("PrintJobResultEvent", fields: [resultEventId], references: [eventId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, attemptNumber], map: "uq_print_job_sample_attempt")
  @@index([status, createdAt], map: "idx_print_job_status_created")
  @@map("print_job")
}

model User {
  id                      String                  @id @db.Uuid
  fullName                String                  @map("full_name")
  username                String
  usernameCanonical       String                  @unique(map: "uq_user_username_canonical") @map("username_canonical")
  email                   String
  emailCanonical          String                  @unique(map: "uq_user_email_canonical") @map("email_canonical")
  phone                   String?
  passwordHash            String                  @map("password_hash")
  role                    UserRole
  status                  UserStatus              @default(ACTIVE)
  initialPasswordDecision InitialPasswordDecision @default(PENDING) @map("initial_password_decision")
  failedLoginAttempts     Int                     @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime?               @map("locked_until") @db.Timestamptz(6)
  lastLoginAt             DateTime?               @map("last_login_at") @db.Timestamptz(6)
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions                 UserSession[]
  passwordResetRequests    PasswordResetRequest[]
  emailChangeRequests      EmailChangeRequest[]
  auditEventsAsTarget      UserAuditEvent[]       @relation("UserAuditTarget")
  auditEventsAsActor       UserAuditEvent[]       @relation("UserAuditActor")
  clientAuditEventsAsActor ClientAuditEvent[]     @relation("ClientAuditActor")
  commercialClientLinks    ClientCommercialUser[]

  @@index([status, createdAt, id], map: "idx_user_status_created_id")
  @@index([role, createdAt, id], map: "idx_user_role_created_id")
  @@index([createdAt, id], map: "idx_user_created_id")
  @@map("app_user")
}

model Client {
  id                          String           @id @db.Uuid
  code                        Int              @unique(map: "uq_client_code") @default(autoincrement())
  personType                  ClientPersonType @map("person_type")
  fullName                    String?          @map("full_name")
  legalName                   String?          @map("legal_name")
  tradeName                   String?          @map("trade_name")
  cpf                         String?          @unique(map: "uq_client_cpf")
  // L5: campos de identidade fiscal e contato/endereco de PJ migram
  // para o Client (antes ficavam em ClientBranch matriz). PF deixa todos
  // estes NULL — sao guardados em ClientUnit (filiais).
  // Fase 0: PF sempre nasce com pelo menos 1 ClientUnit. Se o caller nao
  // fornecer nenhuma, o backend injeta uma fazenda placeholder
  // "Fazenda 1" (ver DEFAULT_PF_UNIT_NAME e ensureDefaultPfUnit em
  // src/clients/client-support.js). PJ continua sem units.
  cnpj                        String?          @unique(map: "uq_client_cnpj")
  cnpjOrder                   String?          @map("cnpj_order") @db.VarChar(4)
  cnpjRoot                    String?          @map("cnpj_root") @db.VarChar(8)
  registrationNumber          String?          @map("registration_number")
  registrationNumberCanonical String?          @unique(map: "uq_client_registration_canonical") @map("registration_number_canonical")
  addressLine                 String?          @map("address_line")
  district                    String?
  city                        String?
  state                       String?          @db.VarChar(2)
  postalCode                  String?          @map("postal_code")
  complement                  String?
  phone                       String?
  email                       String?
  isBuyer                     Boolean          @default(false) @map("is_buyer")
  isSeller                    Boolean          @default(false) @map("is_seller")
  status                      ClientStatus     @default(ACTIVE)
  createdAt                   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  // 14.6.C: GENERATED ALWAYS AS column em PG (migration manual).
  // Prisma le mas nao escreve — nao passar em create/update.
  displayNameLower            String?          @map("display_name_lower") @db.Text
  // 14.7: GENERATED ALWAYS AS columns para busca acento+espaco-insensivel.
  searchNormalized            String?          @map("search_normalized") @db.Text
  searchCompact               String?          @map("search_compact") @db.Text

  units               ClientUnit[]
  ownedSamples        Sample[]               @relation("SampleOwnerClient")
  buyerMovements      SampleMovement[]       @relation("SampleMovementBuyerClient")
  auditEventsAsTarget ClientAuditEvent[]     @relation("ClientAuditTarget")
  commercialUsers     ClientCommercialUser[]

  @@index([cnpjRoot], map: "idx_client_cnpj_root")
  @@index([status, code], map: "idx_client_status_code")
  @@index([createdAt, id], map: "idx_client_created_id")
  @@index([displayNameLower, id], map: "idx_client_display_name_lower_id")
  @@map("client")
}

model ClientUnit {
  id                          String           @id @db.Uuid
  clientId                    String           @map("client_id") @db.Uuid
  name                        String
  code                        Int
  cnpj                        String?
  legalName                   String?          @map("legal_name")
  tradeName                   String?          @map("trade_name")
  phone                       String?
  addressLine                 String?          @map("address_line")
  district                    String?
  city                        String?
  state                       String?          @db.VarChar(2)
  postalCode                  String?          @map("postal_code")
  complement                  String?
  registrationNumber          String?          @map("registration_number")
  registrationNumberCanonical String?          @map("registration_number_canonical")
  car                         String?
  status                      ClientUnitStatus @default(ACTIVE)
  createdAt                   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  client              Client             @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ownedSamples        Sample[]           @relation("SampleOwnerUnit")
  buyerMovements      SampleMovement[]   @relation("SampleMovementBuyerUnit")
  auditEventsAsTarget ClientAuditEvent[] @relation("ClientAuditTargetUnit")

  @@unique([clientId, code], map: "uq_client_unit_client_code")
  @@unique([cnpj], map: "uq_client_unit_cnpj")
  @@unique([registrationNumberCanonical], map: "uq_client_unit_registration_canonical")
  @@index([clientId, status], map: "idx_client_unit_client_status")
  @@index([city, state], map: "idx_client_unit_city_state")
  @@map("client_unit")
}

model ClientCommercialUser {
  clientId  String   @map("client_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([clientId, userId])
  @@index([clientId, createdAt], map: "idx_ccu_client_created")
  @@index([userId, createdAt], map: "idx_ccu_user_created")
  @@map("client_commercial_user")
}

// F5.2: ClientRegistration model removido. A tabela continua no DB como
// `client_registration_deprecated_2026q2` (rename via migration), drop
// definitivo em Phase 10. Para mutations, usar ClientBranch.

model ClientAuditEvent {
  eventId           String               @id @map("event_id") @db.Uuid
  targetClientId    String?              @map("target_client_id") @db.Uuid
  targetUnitId      String?              @map("target_unit_id") @db.Uuid
  actorUserId       String?              @map("actor_user_id") @db.Uuid
  eventType         ClientAuditEventType @map("event_type")
  payload           Json
  reasonText        String?              @map("reason_text")
  requestId         String               @map("request_id")
  correlationId     String?              @map("correlation_id")
  metadataIp        String?              @map("metadata_ip")
  metadataUserAgent String?              @map("metadata_user_agent")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  targetClient Client?     @relation("ClientAuditTarget", fields: [targetClientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  targetUnit   ClientUnit? @relation("ClientAuditTargetUnit", fields: [targetUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actorUser    User?       @relation("ClientAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([targetClientId, createdAt], map: "idx_client_audit_target_created")
  @@index([targetUnitId, createdAt], map: "idx_client_audit_unit_created")
  @@index([actorUserId, createdAt], map: "idx_client_audit_actor_created")
  @@index([eventType, createdAt], map: "idx_client_audit_event_type_created")
  @@index([createdAt], map: "idx_client_audit_created")
  @@map("client_audit_event")
}

model SampleMovement {
  id                  String               @id @db.Uuid
  sampleId            String               @map("sample_id") @db.Uuid
  movementType        SampleMovementType   @map("movement_type")
  status              SampleMovementStatus @default(ACTIVE)
  buyerClientId       String?              @map("buyer_client_id") @db.Uuid
  buyerUnitId         String?              @map("buyer_unit_id") @db.Uuid
  quantitySacks       Int                  @map("quantity_sacks")
  movementDate        DateTime             @map("movement_date") @db.Date
  notes               String?
  reasonText          String?              @map("reason_text")
  buyerClientSnapshot Json?                @map("buyer_client_snapshot")
  buyerUnitSnapshot   Json?                @map("buyer_unit_snapshot")
  version             Int                  @default(0)
  cancelledAt         DateTime?            @map("cancelled_at") @db.Timestamptz(6)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  sample      Sample      @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  buyerClient Client?     @relation("SampleMovementBuyerClient", fields: [buyerClientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  buyerUnit   ClientUnit? @relation("SampleMovementBuyerUnit", fields: [buyerUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([sampleId, status, movementDate, id], map: "idx_sample_movement_sample_status_date_id")
  @@index([sampleId, movementType, status, movementDate, id], map: "idx_sample_movement_sample_type_status_date_id")
  @@index([buyerClientId, movementType, status, movementDate, id], map: "idx_sample_movement_buyer_type_status_date_id")
  @@index([sampleId, status, createdAt, id], map: "idx_sample_movement_sample_status_created_id")
  @@index([sampleId, movementType, status, createdAt, id], map: "idx_sample_movement_sample_type_status_created_id")
  @@index([buyerClientId, movementType, status, createdAt, id], map: "idx_sample_movement_buyer_type_status_created_id")
  @@index([buyerUnitId], map: "idx_sample_movement_buyer_unit")
  @@map("sample_movement")
}

model UserSession {
  id               String                @id @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  expiresAt        DateTime              @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?             @map("revoked_at") @db.Timestamptz(6)
  endReason        UserSessionEndReason? @map("end_reason")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt       DateTime?             @map("last_seen_at") @db.Timestamptz(6)
  createdIp        String?               @map("created_ip")
  createdUserAgent String?               @map("created_user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_user_session_user_created")
  @@index([userId, revokedAt, expiresAt], map: "idx_user_session_lookup")
  @@index([expiresAt], map: "idx_user_session_expires_at")
  @@map("user_session")
}

model PasswordResetRequest {
  id                String    @id @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  emailCanonical    String    @map("email_canonical")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  resendAvailableAt DateTime  @map("resend_available_at") @db.Timestamptz(6)
  retryAvailableAt  DateTime  @map("retry_available_at") @db.Timestamptz(6)
  failedAttempts    Int       @default(0) @map("failed_attempts")
  invalidatedAt     DateTime? @map("invalidated_at") @db.Timestamptz(6)
  consumedAt        DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_password_reset_user_created")
  @@index([emailCanonical, createdAt], map: "idx_password_reset_email_created")
  @@index([retryAvailableAt], map: "idx_password_reset_retry_available")
  @@map("password_reset_request")
}

model EmailChangeRequest {
  id                String    @id @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  newEmail          String    @map("new_email")
  newEmailCanonical String    @map("new_email_canonical")
  reservationKey    String?   @unique(map: "uq_email_change_reservation_key") @map("reservation_key")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  resendAvailableAt DateTime  @map("resend_available_at") @db.Timestamptz(6)
  retryAvailableAt  DateTime  @map("retry_available_at") @db.Timestamptz(6)
  failedAttempts    Int       @default(0) @map("failed_attempts")
  invalidatedAt     DateTime? @map("invalidated_at") @db.Timestamptz(6)
  consumedAt        DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_email_change_user_created")
  @@index([newEmailCanonical, createdAt], map: "idx_email_change_new_email_created")
  @@index([retryAvailableAt], map: "idx_email_change_retry_available")
  @@map("email_change_request")
}

model UserAuditEvent {
  eventId           String             @id @map("event_id") @db.Uuid
  targetUserId      String?            @map("target_user_id") @db.Uuid
  actorUserId       String?            @map("actor_user_id") @db.Uuid
  eventType         UserAuditEventType @map("event_type")
  payload           Json
  reasonText        String?            @map("reason_text")
  requestId         String             @map("request_id")
  correlationId     String?            @map("correlation_id")
  metadataIp        String?            @map("metadata_ip")
  metadataUserAgent String?            @map("metadata_user_agent")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  targetUser User? @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actorUser  User? @relation("UserAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([targetUserId, createdAt], map: "idx_user_audit_target_created")
  @@index([actorUserId, createdAt], map: "idx_user_audit_actor_created")
  @@index([eventType, createdAt], map: "idx_user_audit_event_type_created")
  @@index([createdAt], map: "idx_user_audit_created")
  @@map("user_audit_event")
}

// #5 (Q-02 + Q-25): suporte a header Idempotency-Key em POST /clients e
// POST /clients/:id/units. Cache (scope, key) -> resposta da 1a chamada.
// TTL 24h (D2: cleanup deferido). Header opcional (C1).
model IdempotencyRecord {
  id           String   @id @db.Uuid
  scope        String
  key          String
  statusCode   Int      @map("status_code")
  responseBody Json     @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  @@unique([scope, key], map: "uq_idempotency_scope_key")
  @@index([expiresAt], map: "idx_idempotency_expires")
  @@map("idempotency_record")
}
