generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SampleStatus {
  PHYSICAL_RECEIVED
  REGISTRATION_IN_PROGRESS
  REGISTRATION_CONFIRMED
  QR_PENDING_PRINT
  QR_PRINTED
  CLASSIFICATION_IN_PROGRESS
  CLASSIFIED
  INVALIDATED
}

enum ActorType {
  USER
  SYSTEM
}

enum SourceType {
  WEB    @map("web")
  API    @map("api")
  WORKER @map("worker")
}

enum ModuleType {
  REGISTRATION   @map("registration")
  CLASSIFICATION @map("classification")
  PRINT          @map("print")
  COMMERCIAL     @map("commercial")
  OCR            @map("ocr")
}

enum IdempotencyScope {
  REGISTRATION_CONFIRM
  QR_PRINT
  QR_REPRINT
  CLASSIFICATION_COMPLETE
  COMMERCIAL_STATUS_UPDATE
  INVALIDATE
}

enum SampleEventType {
  SAMPLE_RECEIVED
  REGISTRATION_STARTED
  PHOTO_ADDED
  OCR_EXTRACTED
  OCR_FAILED
  OCR_CONFIRMED
  REGISTRATION_CONFIRMED
  QR_PRINT_REQUESTED
  QR_PRINT_FAILED
  QR_PRINTED
  QR_REPRINT_REQUESTED
  CLASSIFICATION_STARTED
  CLASSIFICATION_SAVED_PARTIAL
  CLASSIFICATION_COMPLETED
  REGISTRATION_UPDATED
  CLASSIFICATION_UPDATED
  COMMERCIAL_STATUS_UPDATED
  SAMPLE_INVALIDATED
  REPORT_EXPORTED
}

enum CommercialStatus {
  OPEN
  SOLD
  LOST
}

enum AttachmentKind {
  ARRIVAL_PHOTO
  CLASSIFICATION_PHOTO
}

enum PrintAction {
  PRINT
  REPRINT
}

enum PrintJobStatus {
  PENDING
  SUCCESS
  FAILED
}

enum UserRole {
  ADMIN
  CLASSIFIER
  REGISTRATION
  COMMERCIAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum InitialPasswordDecision {
  PENDING
  KEPT
  CHANGED
}

enum UserSessionEndReason {
  LOGOUT
  EXPIRED
  PASSWORD_CHANGED
  PASSWORD_RESET
  USERNAME_CHANGED
  ROLE_CHANGED
  INACTIVATED
  REVOKED
}

enum UserAuditEventType {
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  USER_INACTIVATED
  USER_REACTIVATED
  USER_UNLOCKED
  PASSWORD_CHANGED
  PASSWORD_RESET_BY_ADMIN
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  LOGOUT
  SESSION_EXPIRED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGE_CONFIRMED
  INITIAL_PASSWORD_DECISION_RECORDED
}

model Sample {
  id                          String    @id @db.Uuid
  internalLotNumber           String?   @unique(map: "uq_sample_internal_lot") @map("internal_lot_number")
  status                      SampleStatus
  commercialStatus            CommercialStatus @default(OPEN) @map("commercial_status")
  version                     Int       @default(0)
  lastEventSequence           Int       @default(0) @map("last_event_sequence")
  declaredOwner               String?   @map("declared_owner")
  declaredSacks               Int?      @map("declared_sacks")
  declaredHarvest             String?   @map("declared_harvest")
  declaredOriginLot           String?   @map("declared_origin_lot")
  labelPhotoCount             Int       @default(0) @map("label_photo_count")
  latestClassificationVersion Int?      @map("latest_classification_version")
  latestClassificationData    Json?     @map("latest_classification_data")
  classificationDraftData     Json?     @map("classification_draft_data")
  classificationDraftCompletionPercent Int? @map("classification_draft_completion_percent")
  latestType                  String?   @map("latest_type")
  latestScreen                String?   @map("latest_screen")
  latestDefectsCount          Int?      @map("latest_defects_count")
  latestMoisture              Decimal?  @db.Decimal(5, 2) @map("latest_moisture")
  latestDensity               Decimal?  @db.Decimal(6, 2) @map("latest_density")
  latestColorAspect           String?   @map("latest_color_aspect")
  latestNotes                 String?   @map("latest_notes")
  updatedAt                   DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")
  createdAt                   DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  events      SampleEvent[]
  attachments SampleAttachment[]
  printJobs   PrintJob[]

  @@index([status], map: "idx_sample_status")
  @@index([commercialStatus], map: "idx_sample_commercial_status")
  @@index([commercialStatus, updatedAt, id], map: "idx_sample_commercial_updated_id")
  @@index([updatedAt, id], map: "idx_sample_updated_id")
  @@index([declaredOwner], map: "idx_sample_declared_owner")
  @@index([declaredHarvest], map: "idx_sample_declared_harvest")
  @@index([createdAt], map: "idx_sample_created_at")
  @@map("sample")
}

model SampleEvent {
  eventId           String            @id @db.Uuid @map("event_id")
  sampleId          String            @db.Uuid @map("sample_id")
  sequenceNumber    Int               @map("sequence_number")
  eventType         SampleEventType   @map("event_type")
  schemaVersion     Int               @map("schema_version")
  occurredAt        DateTime          @db.Timestamptz(6) @map("occurred_at")
  actorType         ActorType         @map("actor_type")
  actorUserId       String?           @db.Uuid @map("actor_user_id")
  source            SourceType
  payload           Json
  requestId         String            @map("request_id")
  correlationId     String?           @map("correlation_id")
  causationId       String?           @db.Uuid @map("causation_id")
  idempotencyScope  IdempotencyScope? @map("idempotency_scope")
  idempotencyKey    String?           @map("idempotency_key")
  fromStatus        SampleStatus?     @map("from_status")
  toStatus          SampleStatus?     @map("to_status")
  metadataModule    ModuleType        @map("metadata_module")
  metadataIp        String?           @map("metadata_ip")
  metadataUserAgent String?           @map("metadata_user_agent")
  createdAt         DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")

  sample          Sample    @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  requestedByJobs PrintJob[] @relation("PrintJobRequestedEvent")
  resultByJobs    PrintJob[] @relation("PrintJobResultEvent")

  @@unique([sampleId, sequenceNumber], map: "uq_sample_event_sequence")
  @@index([sampleId, occurredAt], map: "idx_sample_event_sample_occurred")
  @@index([eventType, occurredAt], map: "idx_sample_event_type_occurred")
  @@index([sampleId, idempotencyScope, idempotencyKey], map: "idx_sample_event_idempotency_lookup")
  @@map("sample_event")
}

model SampleAttachment {
  id           String         @id @db.Uuid
  sampleId     String         @db.Uuid @map("sample_id")
  kind         AttachmentKind
  storagePath  String         @map("storage_path")
  mimeType     String?        @map("mime_type")
  sizeBytes    Int?           @map("size_bytes")
  checksumSha256 String?      @map("checksum_sha256")
  createdAt    DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")

  sample Sample @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, kind], map: "uq_sample_attachment_sample_kind")
  @@index([sampleId, createdAt], map: "idx_attachment_sample_created")
  @@map("sample_attachment")
}

model PrintJob {
  id               String         @id @db.Uuid
  sampleId         String         @db.Uuid @map("sample_id")
  printAction      PrintAction    @map("print_action")
  attemptNumber    Int            @map("attempt_number")
  status           PrintJobStatus
  printerId        String?        @map("printer_id")
  error            String?
  requestedEventId String         @db.Uuid @map("requested_event_id")
  resultEventId    String?        @db.Uuid @map("result_event_id")
  createdAt        DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6) @map("updated_at")

  sample         Sample      @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  requestedEvent SampleEvent @relation("PrintJobRequestedEvent", fields: [requestedEventId], references: [eventId], onDelete: Restrict, onUpdate: Cascade)
  resultEvent    SampleEvent? @relation("PrintJobResultEvent", fields: [resultEventId], references: [eventId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, printAction, attemptNumber], map: "uq_print_job_sample_action_attempt")
  @@index([status, createdAt], map: "idx_print_job_status_created")
  @@map("print_job")
}

model User {
  id                      String                  @id @db.Uuid
  fullName                String                  @map("full_name")
  username                String
  usernameCanonical       String                  @unique(map: "uq_user_username_canonical") @map("username_canonical")
  email                   String
  emailCanonical          String                  @unique(map: "uq_user_email_canonical") @map("email_canonical")
  phone                   String?
  passwordHash            String                  @map("password_hash")
  role                    UserRole
  status                  UserStatus              @default(ACTIVE)
  initialPasswordDecision InitialPasswordDecision @default(PENDING) @map("initial_password_decision")
  failedLoginAttempts     Int                     @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime?               @db.Timestamptz(6) @map("locked_until")
  lastLoginAt             DateTime?               @db.Timestamptz(6) @map("last_login_at")
  createdAt               DateTime                @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt               DateTime                @updatedAt @db.Timestamptz(6) @map("updated_at")

  sessions              UserSession[]
  passwordResetRequests PasswordResetRequest[]
  emailChangeRequests   EmailChangeRequest[]
  auditEventsAsTarget   UserAuditEvent[] @relation("UserAuditTarget")
  auditEventsAsActor    UserAuditEvent[] @relation("UserAuditActor")

  @@index([status, createdAt, id], map: "idx_user_status_created_id")
  @@index([role, createdAt, id], map: "idx_user_role_created_id")
  @@index([createdAt, id], map: "idx_user_created_id")
  @@map("app_user")
}

model UserSession {
  id               String             @id @db.Uuid
  userId           String             @db.Uuid @map("user_id")
  expiresAt        DateTime           @db.Timestamptz(6) @map("expires_at")
  revokedAt        DateTime?          @db.Timestamptz(6) @map("revoked_at")
  endReason        UserSessionEndReason? @map("end_reason")
  createdAt        DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  lastSeenAt       DateTime?          @db.Timestamptz(6) @map("last_seen_at")
  createdIp        String?            @map("created_ip")
  createdUserAgent String?            @map("created_user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_user_session_user_created")
  @@index([userId, revokedAt, expiresAt], map: "idx_user_session_lookup")
  @@index([expiresAt], map: "idx_user_session_expires_at")
  @@map("user_session")
}

model PasswordResetRequest {
  id                String    @id @db.Uuid
  userId            String    @db.Uuid @map("user_id")
  emailCanonical    String    @map("email_canonical")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @db.Timestamptz(6) @map("expires_at")
  resendAvailableAt DateTime  @db.Timestamptz(6) @map("resend_available_at")
  retryAvailableAt  DateTime  @db.Timestamptz(6) @map("retry_available_at")
  failedAttempts    Int       @default(0) @map("failed_attempts")
  invalidatedAt     DateTime? @db.Timestamptz(6) @map("invalidated_at")
  consumedAt        DateTime? @db.Timestamptz(6) @map("consumed_at")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_password_reset_user_created")
  @@index([emailCanonical, createdAt], map: "idx_password_reset_email_created")
  @@index([retryAvailableAt], map: "idx_password_reset_retry_available")
  @@map("password_reset_request")
}

model EmailChangeRequest {
  id                String    @id @db.Uuid
  userId            String    @db.Uuid @map("user_id")
  newEmail          String    @map("new_email")
  newEmailCanonical String    @map("new_email_canonical")
  reservationKey    String?   @unique(map: "uq_email_change_reservation_key") @map("reservation_key")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @db.Timestamptz(6) @map("expires_at")
  resendAvailableAt DateTime  @db.Timestamptz(6) @map("resend_available_at")
  retryAvailableAt  DateTime  @db.Timestamptz(6) @map("retry_available_at")
  failedAttempts    Int       @default(0) @map("failed_attempts")
  invalidatedAt     DateTime? @db.Timestamptz(6) @map("invalidated_at")
  consumedAt        DateTime? @db.Timestamptz(6) @map("consumed_at")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_email_change_user_created")
  @@index([newEmailCanonical, createdAt], map: "idx_email_change_new_email_created")
  @@index([retryAvailableAt], map: "idx_email_change_retry_available")
  @@map("email_change_request")
}

model UserAuditEvent {
  eventId           String             @id @db.Uuid @map("event_id")
  targetUserId      String?            @db.Uuid @map("target_user_id")
  actorUserId       String?            @db.Uuid @map("actor_user_id")
  eventType         UserAuditEventType @map("event_type")
  payload           Json
  reasonText        String?            @map("reason_text")
  requestId         String             @map("request_id")
  correlationId     String?            @map("correlation_id")
  metadataIp        String?            @map("metadata_ip")
  metadataUserAgent String?            @map("metadata_user_agent")
  createdAt         DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")

  targetUser User? @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actorUser  User? @relation("UserAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([targetUserId, createdAt], map: "idx_user_audit_target_created")
  @@index([actorUserId, createdAt], map: "idx_user_audit_actor_created")
  @@index([eventType, createdAt], map: "idx_user_audit_event_type_created")
  @@index([createdAt], map: "idx_user_audit_created")
  @@map("user_audit_event")
}
