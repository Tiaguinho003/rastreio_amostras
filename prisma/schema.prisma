generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SampleStatus {
  PHYSICAL_RECEIVED
  REGISTRATION_IN_PROGRESS
  REGISTRATION_CONFIRMED
  QR_PENDING_PRINT
  QR_PRINTED
  CLASSIFICATION_IN_PROGRESS
  CLASSIFIED
  INVALIDATED
}

enum ActorType {
  USER
  SYSTEM
}

enum SourceType {
  WEB    @map("web")
  API    @map("api")
  WORKER @map("worker")
}

enum ModuleType {
  REGISTRATION   @map("registration")
  CLASSIFICATION @map("classification")
  PRINT          @map("print")
  COMMERCIAL     @map("commercial")
}

enum IdempotencyScope {
  REGISTRATION_CONFIRM
  QR_PRINT
  QR_REPRINT
  CLASSIFICATION_COMPLETE
  COMMERCIAL_STATUS_UPDATE
  INVALIDATE
  LEGACY_SKELETON_CREATE
}

enum SampleEventType {
  SAMPLE_RECEIVED
  REGISTRATION_STARTED
  PHOTO_ADDED
  REGISTRATION_CONFIRMED
  QR_PRINT_REQUESTED
  QR_PRINT_FAILED
  QR_PRINTED
  QR_REPRINT_REQUESTED
  CLASSIFICATION_STARTED
  CLASSIFICATION_SAVED_PARTIAL
  CLASSIFICATION_COMPLETED
  REGISTRATION_UPDATED
  CLASSIFICATION_UPDATED
  SALE_CREATED
  SALE_UPDATED
  SALE_CANCELLED
  LOSS_RECORDED
  LOSS_UPDATED
  LOSS_CANCELLED
  COMMERCIAL_STATUS_UPDATED
  SAMPLE_INVALIDATED
  REPORT_EXPORTED
  PHYSICAL_SAMPLE_SENT
  PHYSICAL_SAMPLE_SEND_UPDATED
  PHYSICAL_SAMPLE_SEND_CANCELLED
  CLASSIFICATION_EXTRACTION_COMPLETED
  CLASSIFICATION_EXTRACTION_FAILED
}

enum CommercialStatus {
  OPEN
  PARTIALLY_SOLD
  SOLD
  LOST
}

enum ClientPersonType {
  PF
  PJ
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum ClientRegistrationStatus {
  ACTIVE
  INACTIVE
}

enum ClientBranchStatus {
  ACTIVE
  INACTIVE
}

enum SampleMovementType {
  SALE
  LOSS
}

enum SampleMovementStatus {
  ACTIVE
  CANCELLED
}

enum SampleSource {
  LIVE
  LEGACY_BACKFILL
}

enum ClientAuditEventType {
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_INACTIVATED
  CLIENT_REACTIVATED
  CLIENT_REGISTRATION_CREATED
  CLIENT_REGISTRATION_UPDATED
  CLIENT_REGISTRATION_INACTIVATED
  CLIENT_REGISTRATION_REACTIVATED
}

enum ClassificationType {
  PREPARADO
  LOW_CAFF
  BICA
}

enum AttachmentKind {
  CLASSIFICATION_PHOTO
}

enum PrintAction {
  PRINT
  REPRINT
}

enum PrintJobStatus {
  PENDING
  SUCCESS
  FAILED
}

enum UserRole {
  ADMIN
  CLASSIFIER
  REGISTRATION
  COMMERCIAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum InitialPasswordDecision {
  PENDING
  KEPT
  CHANGED
}

enum UserSessionEndReason {
  LOGOUT
  EXPIRED
  PASSWORD_CHANGED
  PASSWORD_RESET
  USERNAME_CHANGED
  ROLE_CHANGED
  INACTIVATED
  REVOKED
}

enum UserAuditEventType {
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  USER_INACTIVATED
  USER_REACTIVATED
  USER_UNLOCKED
  PASSWORD_CHANGED
  PASSWORD_RESET_BY_ADMIN
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  LOGOUT
  SESSION_EXPIRED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGE_CONFIRMED
  INITIAL_PASSWORD_DECISION_RECORDED
}

model Sample {
  id                          String    @id @db.Uuid
  internalLotNumber           String?   @unique(map: "uq_sample_internal_lot") @map("internal_lot_number")
  status                      SampleStatus
  commercialStatus            CommercialStatus @default(OPEN) @map("commercial_status")
  version                     Int       @default(0)
  lastEventSequence           Int       @default(0) @map("last_event_sequence")
  ownerClientId               String?   @db.Uuid @map("owner_client_id")
  ownerRegistrationId         String?   @db.Uuid @map("owner_registration_id")
  ownerBranchId               String?   @db.Uuid @map("owner_branch_id")
  declaredOwner               String?   @map("declared_owner")
  declaredSacks               Int?      @map("declared_sacks")
  declaredHarvest             String?   @map("declared_harvest")
  declaredOriginLot           String?   @map("declared_origin_lot")
  declaredLocation            String?   @db.VarChar(30) @map("declared_location")
  classificationType          ClassificationType? @map("classification_type")
  soldSacks                   Int       @default(0) @map("sold_sacks")
  lostSacks                   Int       @default(0) @map("lost_sacks")
  latestClassificationVersion Int?      @map("latest_classification_version")
  latestClassificationData    Json?     @map("latest_classification_data")
  classificationDraftData     Json?     @map("classification_draft_data")
  classificationDraftCompletionPercent Int? @map("classification_draft_completion_percent")
  latestType                  String?   @map("latest_type")
  latestScreen                String?   @map("latest_screen")
  latestDefectsCount          Int?      @map("latest_defects_count")
  latestDensity               Decimal?  @db.Decimal(6, 2) @map("latest_density")
  latestColorAspect           String?   @map("latest_color_aspect")
  latestNotes                 String?   @map("latest_notes")
  classifiedAt                DateTime? @db.Timestamptz(6) @map("classified_at")
  source                      SampleSource @default(LIVE) @map("source")
  updatedAt                   DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")
  createdAt                   DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  ownerClient       Client?             @relation("SampleOwnerClient", fields: [ownerClientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ownerRegistration ClientRegistration? @relation("SampleOwnerRegistration", fields: [ownerRegistrationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ownerBranch       ClientBranch?       @relation("SampleOwnerBranch", fields: [ownerBranchId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  events            SampleEvent[]
  attachments       SampleAttachment[]
  printJobs         PrintJob[]
  movements         SampleMovement[]

  @@index([status], map: "idx_sample_status")
  @@index([commercialStatus], map: "idx_sample_commercial_status")
  @@index([commercialStatus, updatedAt, id], map: "idx_sample_commercial_updated_id")
  @@index([updatedAt, id], map: "idx_sample_updated_id")
  @@index([declaredOwner], map: "idx_sample_declared_owner")
  @@index([declaredHarvest], map: "idx_sample_declared_harvest")
  @@index([createdAt], map: "idx_sample_created_at")
  @@index([ownerClientId], map: "idx_sample_owner_client")
  @@index([ownerRegistrationId], map: "idx_sample_owner_registration")
  @@index([ownerBranchId], map: "idx_sample_owner_branch")
  @@index([status, updatedAt, id], map: "idx_sample_status_updated_id")
  @@index([status, createdAt, id], map: "idx_sample_status_created_id")
  @@index([status, commercialStatus, classifiedAt], map: "idx_sample_classified_availability")
  @@index([source], map: "idx_sample_source")
  @@map("sample")
}

model SampleEvent {
  eventId           String            @id @db.Uuid @map("event_id")
  sampleId          String            @db.Uuid @map("sample_id")
  sequenceNumber    Int               @map("sequence_number")
  eventType         SampleEventType   @map("event_type")
  schemaVersion     Int               @map("schema_version")
  occurredAt        DateTime          @db.Timestamptz(6) @map("occurred_at")
  actorType         ActorType         @map("actor_type")
  actorUserId       String?           @db.Uuid @map("actor_user_id")
  source            SourceType
  payload           Json
  requestId         String            @map("request_id")
  correlationId     String?           @map("correlation_id")
  causationId       String?           @db.Uuid @map("causation_id")
  idempotencyScope  IdempotencyScope? @map("idempotency_scope")
  idempotencyKey    String?           @map("idempotency_key")
  fromStatus        SampleStatus?     @map("from_status")
  toStatus          SampleStatus?     @map("to_status")
  metadataModule    ModuleType        @map("metadata_module")
  metadataIp        String?           @map("metadata_ip")
  metadataUserAgent String?           @map("metadata_user_agent")
  createdAt         DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")

  sample          Sample    @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  requestedByJobs PrintJob[] @relation("PrintJobRequestedEvent")
  resultByJobs    PrintJob[] @relation("PrintJobResultEvent")

  @@unique([sampleId, sequenceNumber], map: "uq_sample_event_sequence")
  @@index([sampleId, occurredAt], map: "idx_sample_event_sample_occurred")
  @@index([eventType, occurredAt], map: "idx_sample_event_type_occurred")
  @@index([sampleId, idempotencyScope, idempotencyKey], map: "idx_sample_event_idempotency_lookup")
  @@map("sample_event")
}

model SampleAttachment {
  id           String         @id @db.Uuid
  sampleId     String         @db.Uuid @map("sample_id")
  kind         AttachmentKind
  storagePath  String         @map("storage_path")
  mimeType     String?        @map("mime_type")
  sizeBytes    Int?           @map("size_bytes")
  checksumSha256 String?      @map("checksum_sha256")
  createdAt    DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")

  sample Sample @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, kind], map: "uq_sample_attachment_sample_kind")
  @@index([sampleId, createdAt], map: "idx_attachment_sample_created")
  @@map("sample_attachment")
}

model PrintJob {
  id               String         @id @db.Uuid
  sampleId         String         @db.Uuid @map("sample_id")
  printAction      PrintAction    @map("print_action")
  attemptNumber    Int            @map("attempt_number")
  status           PrintJobStatus
  printerId        String?        @map("printer_id")
  error            String?
  requestedEventId String         @db.Uuid @map("requested_event_id")
  resultEventId    String?        @db.Uuid @map("result_event_id")
  createdAt        DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6) @map("updated_at")

  sample         Sample      @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  requestedEvent SampleEvent @relation("PrintJobRequestedEvent", fields: [requestedEventId], references: [eventId], onDelete: Restrict, onUpdate: Cascade)
  resultEvent    SampleEvent? @relation("PrintJobResultEvent", fields: [resultEventId], references: [eventId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([sampleId, printAction, attemptNumber], map: "uq_print_job_sample_action_attempt")
  @@index([status, createdAt], map: "idx_print_job_status_created")
  @@map("print_job")
}

model User {
  id                      String                  @id @db.Uuid
  fullName                String                  @map("full_name")
  username                String
  usernameCanonical       String                  @unique(map: "uq_user_username_canonical") @map("username_canonical")
  email                   String
  emailCanonical          String                  @unique(map: "uq_user_email_canonical") @map("email_canonical")
  phone                   String?
  passwordHash            String                  @map("password_hash")
  role                    UserRole
  status                  UserStatus              @default(ACTIVE)
  initialPasswordDecision InitialPasswordDecision @default(PENDING) @map("initial_password_decision")
  failedLoginAttempts     Int                     @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime?               @db.Timestamptz(6) @map("locked_until")
  lastLoginAt             DateTime?               @db.Timestamptz(6) @map("last_login_at")
  createdAt               DateTime                @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt               DateTime                @updatedAt @db.Timestamptz(6) @map("updated_at")

  sessions              UserSession[]
  passwordResetRequests PasswordResetRequest[]
  emailChangeRequests   EmailChangeRequest[]
  auditEventsAsTarget   UserAuditEvent[] @relation("UserAuditTarget")
  auditEventsAsActor    UserAuditEvent[] @relation("UserAuditActor")
  clientAuditEventsAsActor    ClientAuditEvent[]    @relation("ClientAuditActor")
  commercialClientLinks       ClientCommercialUser[]

  @@index([status, createdAt, id], map: "idx_user_status_created_id")
  @@index([role, createdAt, id], map: "idx_user_role_created_id")
  @@index([createdAt, id], map: "idx_user_created_id")
  @@map("app_user")
}

model Client {
  id                String            @id @db.Uuid
  code              Int               @unique(map: "uq_client_code") @default(autoincrement())
  personType        ClientPersonType  @map("person_type")
  fullName          String?           @map("full_name")
  legalName         String?           @map("legal_name")
  tradeName         String?           @map("trade_name")
  cpf               String?
  cnpj              String?
  documentCanonical String?           @unique(map: "uq_client_document_canonical") @map("document_canonical")
  // F5.0: cnpj_root e indexado mas NAO unique ainda (ha grupos COOPERCITRUS/COFCO).
  // F5.1 funde via wizard e altera para UNIQUE.
  cnpjRoot          String?           @map("cnpj_root") @db.VarChar(8)
  phone             String?
  isBuyer           Boolean           @default(false) @map("is_buyer")
  isSeller          Boolean           @default(false) @map("is_seller")
  status            ClientStatus      @default(ACTIVE)
  createdAt         DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime          @updatedAt @db.Timestamptz(6) @map("updated_at")

  registrations       ClientRegistration[]
  branches            ClientBranch[]
  ownedSamples        Sample[]           @relation("SampleOwnerClient")
  buyerMovements      SampleMovement[]   @relation("SampleMovementBuyerClient")
  auditEventsAsTarget ClientAuditEvent[] @relation("ClientAuditTarget")
  commercialUsers     ClientCommercialUser[]

  @@index([status, code], map: "idx_client_status_code")
  @@index([createdAt, id], map: "idx_client_created_id")
  @@index([cnpjRoot], map: "idx_client_cnpj_root")
  @@map("client")
}

model ClientBranch {
  id                          String              @id @db.Uuid
  clientId                    String              @db.Uuid @map("client_id")
  name                        String?
  isPrimary                   Boolean             @default(false) @map("is_primary")
  code                        Int
  cnpj                        String?
  cnpjOrder                   String?             @map("cnpj_order") @db.VarChar(4)
  legalName                   String?             @map("legal_name")
  tradeName                   String?             @map("trade_name")
  phone                       String?
  addressLine                 String?             @map("address_line")
  district                    String?
  city                        String?
  state                       String?             @db.VarChar(2)
  postalCode                  String?             @map("postal_code")
  complement                  String?
  registrationNumber          String?             @map("registration_number")
  registrationNumberCanonical String?             @map("registration_number_canonical")
  registrationType            String?             @map("registration_type")
  status                      ClientBranchStatus  @default(ACTIVE)
  createdAt                   DateTime            @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                   DateTime            @updatedAt @db.Timestamptz(6) @map("updated_at")

  client                      Client              @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ownedSamples                Sample[]            @relation("SampleOwnerBranch")
  buyerMovements              SampleMovement[]    @relation("SampleMovementBuyerBranch")

  @@unique([clientId, code], map: "uq_client_branch_client_code")
  @@unique([cnpj], map: "uq_client_branch_cnpj")
  @@unique([registrationNumberCanonical], map: "uq_client_branch_registration_canonical")
  @@index([clientId, status, isPrimary], map: "idx_client_branch_client_status_primary")
  @@index([city, state], map: "idx_client_branch_city_state")
  @@map("client_branch")
}

model ClientCommercialUser {
  clientId  String   @db.Uuid @map("client_id")
  userId    String   @db.Uuid @map("user_id")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([clientId, userId])
  @@index([clientId, createdAt], map: "idx_ccu_client_created")
  @@index([userId, createdAt], map: "idx_ccu_user_created")
  @@map("client_commercial_user")
}

model ClientRegistration {
  id                         String                   @id @db.Uuid
  clientId                   String                   @db.Uuid @map("client_id")
  status                     ClientRegistrationStatus @default(ACTIVE)
  registrationNumber         String                   @map("registration_number")
  registrationNumberCanonical String                  @unique(map: "uq_client_registration_number_canonical") @map("registration_number_canonical")
  registrationType           String                   @map("registration_type")
  addressLine                String                   @map("address_line")
  district                   String
  city                       String
  state                      String                   @db.VarChar(2)
  postalCode                 String                   @map("postal_code")
  complement                 String?
  createdAt                  DateTime                 @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                  DateTime                 @updatedAt @db.Timestamptz(6) @map("updated_at")

  client                      Client             @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ownerSamples                Sample[]           @relation("SampleOwnerRegistration")
  buyerMovements              SampleMovement[]   @relation("SampleMovementBuyerRegistration")
  auditEventsAsTarget         ClientAuditEvent[] @relation("ClientAuditTargetRegistration")

  @@unique([id, clientId], map: "uq_client_registration_id_client")
  @@index([clientId, status, createdAt], map: "idx_client_registration_client_status_created")
  @@map("client_registration")
}

model ClientAuditEvent {
  eventId              String               @id @db.Uuid @map("event_id")
  targetClientId       String?              @db.Uuid @map("target_client_id")
  targetRegistrationId String?              @db.Uuid @map("target_registration_id")
  actorUserId          String?              @db.Uuid @map("actor_user_id")
  eventType            ClientAuditEventType @map("event_type")
  payload              Json
  reasonText           String?              @map("reason_text")
  requestId            String               @map("request_id")
  correlationId        String?              @map("correlation_id")
  metadataIp           String?              @map("metadata_ip")
  metadataUserAgent    String?              @map("metadata_user_agent")
  createdAt            DateTime             @default(now()) @db.Timestamptz(6) @map("created_at")

  targetClient       Client?             @relation("ClientAuditTarget", fields: [targetClientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  targetRegistration ClientRegistration? @relation("ClientAuditTargetRegistration", fields: [targetRegistrationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actorUser          User?               @relation("ClientAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([targetClientId, createdAt], map: "idx_client_audit_target_created")
  @@index([targetRegistrationId, createdAt], map: "idx_client_audit_registration_created")
  @@index([actorUserId, createdAt], map: "idx_client_audit_actor_created")
  @@index([eventType, createdAt], map: "idx_client_audit_event_type_created")
  @@index([createdAt], map: "idx_client_audit_created")
  @@map("client_audit_event")
}

model SampleMovement {
  id                       String               @id @db.Uuid
  sampleId                 String               @db.Uuid @map("sample_id")
  movementType             SampleMovementType   @map("movement_type")
  status                   SampleMovementStatus @default(ACTIVE)
  buyerClientId            String?              @db.Uuid @map("buyer_client_id")
  buyerRegistrationId      String?              @db.Uuid @map("buyer_registration_id")
  buyerBranchId            String?              @db.Uuid @map("buyer_branch_id")
  quantitySacks            Int                  @map("quantity_sacks")
  movementDate             DateTime             @db.Date @map("movement_date")
  notes                    String?
  reasonText               String?              @map("reason_text")
  buyerClientSnapshot      Json?                @map("buyer_client_snapshot")
  buyerRegistrationSnapshot Json?               @map("buyer_registration_snapshot")
  buyerBranchSnapshot      Json?                @map("buyer_branch_snapshot")
  version                  Int                  @default(0)
  cancelledAt              DateTime?            @db.Timestamptz(6) @map("cancelled_at")
  createdAt                DateTime             @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                DateTime             @updatedAt @db.Timestamptz(6) @map("updated_at")

  sample            Sample              @relation(fields: [sampleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  buyerClient       Client?             @relation("SampleMovementBuyerClient", fields: [buyerClientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  buyerRegistration ClientRegistration? @relation("SampleMovementBuyerRegistration", fields: [buyerRegistrationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  buyerBranch       ClientBranch?       @relation("SampleMovementBuyerBranch", fields: [buyerBranchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([sampleId, status, movementDate, id], map: "idx_sample_movement_sample_status_date_id")
  @@index([sampleId, movementType, status, movementDate, id], map: "idx_sample_movement_sample_type_status_date_id")
  @@index([buyerClientId, movementType, status, movementDate, id], map: "idx_sample_movement_buyer_type_status_date_id")
  @@index([sampleId, status, createdAt, id], map: "idx_sample_movement_sample_status_created_id")
  @@index([sampleId, movementType, status, createdAt, id], map: "idx_sample_movement_sample_type_status_created_id")
  @@index([buyerClientId, movementType, status, createdAt, id], map: "idx_sample_movement_buyer_type_status_created_id")
  @@index([buyerBranchId], map: "idx_sample_movement_buyer_branch")
  @@map("sample_movement")
}

model UserSession {
  id               String             @id @db.Uuid
  userId           String             @db.Uuid @map("user_id")
  expiresAt        DateTime           @db.Timestamptz(6) @map("expires_at")
  revokedAt        DateTime?          @db.Timestamptz(6) @map("revoked_at")
  endReason        UserSessionEndReason? @map("end_reason")
  createdAt        DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  lastSeenAt       DateTime?          @db.Timestamptz(6) @map("last_seen_at")
  createdIp        String?            @map("created_ip")
  createdUserAgent String?            @map("created_user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_user_session_user_created")
  @@index([userId, revokedAt, expiresAt], map: "idx_user_session_lookup")
  @@index([expiresAt], map: "idx_user_session_expires_at")
  @@map("user_session")
}

model PasswordResetRequest {
  id                String    @id @db.Uuid
  userId            String    @db.Uuid @map("user_id")
  emailCanonical    String    @map("email_canonical")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @db.Timestamptz(6) @map("expires_at")
  resendAvailableAt DateTime  @db.Timestamptz(6) @map("resend_available_at")
  retryAvailableAt  DateTime  @db.Timestamptz(6) @map("retry_available_at")
  failedAttempts    Int       @default(0) @map("failed_attempts")
  invalidatedAt     DateTime? @db.Timestamptz(6) @map("invalidated_at")
  consumedAt        DateTime? @db.Timestamptz(6) @map("consumed_at")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_password_reset_user_created")
  @@index([emailCanonical, createdAt], map: "idx_password_reset_email_created")
  @@index([retryAvailableAt], map: "idx_password_reset_retry_available")
  @@map("password_reset_request")
}

model EmailChangeRequest {
  id                String    @id @db.Uuid
  userId            String    @db.Uuid @map("user_id")
  newEmail          String    @map("new_email")
  newEmailCanonical String    @map("new_email_canonical")
  reservationKey    String?   @unique(map: "uq_email_change_reservation_key") @map("reservation_key")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @db.Timestamptz(6) @map("expires_at")
  resendAvailableAt DateTime  @db.Timestamptz(6) @map("resend_available_at")
  retryAvailableAt  DateTime  @db.Timestamptz(6) @map("retry_available_at")
  failedAttempts    Int       @default(0) @map("failed_attempts")
  invalidatedAt     DateTime? @db.Timestamptz(6) @map("invalidated_at")
  consumedAt        DateTime? @db.Timestamptz(6) @map("consumed_at")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_email_change_user_created")
  @@index([newEmailCanonical, createdAt], map: "idx_email_change_new_email_created")
  @@index([retryAvailableAt], map: "idx_email_change_retry_available")
  @@map("email_change_request")
}

model UserAuditEvent {
  eventId           String             @id @db.Uuid @map("event_id")
  targetUserId      String?            @db.Uuid @map("target_user_id")
  actorUserId       String?            @db.Uuid @map("actor_user_id")
  eventType         UserAuditEventType @map("event_type")
  payload           Json
  reasonText        String?            @map("reason_text")
  requestId         String             @map("request_id")
  correlationId     String?            @map("correlation_id")
  metadataIp        String?            @map("metadata_ip")
  metadataUserAgent String?            @map("metadata_user_agent")
  createdAt         DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")

  targetUser User? @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actorUser  User? @relation("UserAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([targetUserId, createdAt], map: "idx_user_audit_target_created")
  @@index([actorUserId, createdAt], map: "idx_user_audit_actor_created")
  @@index([eventType, createdAt], map: "idx_user_audit_event_type_created")
  @@index([createdAt], map: "idx_user_audit_created")
  @@map("user_audit_event")
}

