# Homolog environment template (do not use in production)

APP_PORT=3001
HOMOLOG_DB_PORT=55433

POSTGRES_USER=rastreio_app
POSTGRES_PASSWORD=change-me-homolog-db-password
POSTGRES_DB=rastreio_homolog

DATABASE_URL=postgresql://rastreio_app:change-me-homolog-db-password@127.0.0.1:55433/rastreio_homolog?schema=public

AUTH_SECRET=replace-with-strong-secret-min-16-chars
BOOTSTRAP_ADMIN_FULL_NAME="Homolog Admin"
BOOTSTRAP_ADMIN_USERNAME="homolog_admin"
BOOTSTRAP_ADMIN_EMAIL="homolog_admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="change-me-now"

# Optional one-time import from legacy env auth during seed
# LOCAL_AUTH_USERS_JSON=[{"id":"00000000-0000-0000-0000-000000000901","username":"homolog_admin","password":"change-me-now","role":"ADMIN","displayName":"Homolog Admin"}]

EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change-me-smtp-user
SMTP_PASS=change-me-smtp-password
SMTP_FROM=no-reply@example.com

UPLOADS_DIR=/srv/rastreio/homolog/uploads
BACKUP_ROOT=/srv/rastreio/homolog/backups
API_BASE_URL=http://localhost:3001
SMOKE_USERNAME=homolog_admin
SMOKE_PASSWORD=replace-with-known-homolog-password
