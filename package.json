{
  "name": "rastreio-interno-amostras",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "description": "Sistema fullstack para rastreio interno de amostras com registro, QR, classificacao e operacao on-premise",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "runtime:compose": "bash scripts/runtime/compose.sh",
    "runtime:migrate": "bash scripts/runtime/migrate.sh",
    "runtime:seed": "bash scripts/runtime/seed.sh",
    "runtime:smoke": "bash scripts/runtime/smoke.sh",
    "runtime:preflight": "bash scripts/runtime/preflight.sh",
    "db:verify:phases-1-4": "bash scripts/db/verify-phases-1-4.sh",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src lib components scripts",
    "lint:fix": "eslint --fix app src lib components scripts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\"",
    "validate:schemas": "node scripts/validate-schemas.js",
    "generate:fichas": "node scripts/generate-classification-sheet.mjs",
    "test:contracts": "node --test tests/event-contract.test.js",
    "test:unit": "node --test tests/local-auth.test.js tests/backend-api-auth-mode.test.js tests/session-cookie-policy.test.js tests/local-upload-service.test.js tests/client-support.test.js tests/roles.test.js tests/rate-limiter.test.js tests/normalize-conferred-by.test.js",
    "test:integration:db": "node --test --test-concurrency=1 tests/**/*.integration.test.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:up": "docker compose -f compose/development.yml up -d db",
    "db:down": "docker compose -f compose/development.yml down",
    "db:logs": "docker compose -f compose/development.yml logs -f db",
    "test": "npm run validate:schemas && npm run test:contracts && npm run test:unit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "file-type": "^22.0.1",
    "next": "^15.5.12",
    "nodemailer": "^8.0.1",
    "openai": "^6.34.0",
    "pdf-lib": "^1.17.1",
    "qr-scanner": "^1.4.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^6.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
