# PostgreSQL for local development/testing (see docker-compose.yml)
DATABASE_URL="postgresql://rastreio_app:rastreio_app@localhost:55432/rastreio_test?schema=public"

# Auth/local users
# Production: use strong AUTH_SECRET and passwordHash entries only.
# Development: plaintext "password" can be allowed with LOCAL_AUTH_ALLOW_PLAINTEXT_PASSWORDS=true.
AUTH_SECRET="replace-with-strong-secret-min-16-chars"
AUTH_HEADER_FALLBACK_ENABLED="true"
LOCAL_AUTH_ALLOW_PLAINTEXT_PASSWORDS="true"
LOCAL_AUTH_USERS_JSON='[{"id":"00000000-0000-0000-0000-000000000001","username":"admin","passwordHash":"$2b$10$replace_with_bcrypt_hash","role":"ADMIN","displayName":"Administrador"},{"id":"00000000-0000-0000-0000-000000000002","username":"classificador","passwordHash":"$2b$10$replace_with_bcrypt_hash","role":"CLASSIFIER","displayName":"Classificador"}]'

# Local uploads directory (MVP)
UPLOADS_DIR="./data/uploads"
