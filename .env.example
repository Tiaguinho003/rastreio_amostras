# PostgreSQL for local development/testing (see docker-compose.yml)
DATABASE_URL="postgresql://rastreio_app:rastreio_app@localhost:55432/rastreio_test?schema=public"

# Auth
AUTH_SECRET="replace-with-strong-secret-min-16-chars"

# Bootstrap admin for initial seed
BOOTSTRAP_ADMIN_FULL_NAME="Administrador"
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_EMAIL="admin@example.local"
BOOTSTRAP_ADMIN_PASSWORD="change-me-now"

# Optional one-time import from legacy env auth during seed
# LOCAL_AUTH_USERS_JSON='[{"id":"00000000-0000-0000-0000-000000000001","username":"admin","password":"change-me-now","role":"ADMIN","displayName":"Administrador"}]'

# Email transport for local development
EMAIL_TRANSPORT="outbox"
EMAIL_OUTBOX_DIR="./data/email-outbox"
EMAIL_OUTBOX_FROM="rastreio@safras.local"

# Local uploads directory (MVP)
UPLOADS_DIR="./data/uploads"
